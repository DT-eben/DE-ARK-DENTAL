<script>
  const nav = document.querySelector('nav');
  const paintNav = () => nav.classList.toggle('scrolled', window.scrollY > 12);
  window.addEventListener('scroll', paintNav, {passive:true}); paintNav();

  const burger = document.querySelector('.burger');
  const mpanel = document.querySelector('.mpanel');
  burger.addEventListener('click', () => mpanel.classList.add('open'));
  mpanel.querySelectorAll('a, .close').forEach(el => el.addEventListener('click', () => mpanel.classList.remove('open')));

  const io = new IntersectionObserver(entries => {
    entries.forEach((e,i) => {
      if(e.isIntersecting){ setTimeout(()=>e.target.classList.add('in'), (i%6)*70); io.unobserve(e.target); }
    });
  }, {threshold:.12});
  document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));

  document.querySelectorAll('.yr').forEach(el => el.textContent = new Date().getFullYear());

  /* symptom finder */
  const data = {
    ache: {title:'You likely need: Fillings or Root Canal Treatment', text:'Persistent toothache often means decay or an infected nerve. We start with an exam, then treat with a filling — or RCT if the nerve is involved.', icon:'<path d="M4 9l8-5 8 5-8 5-8-5z"/><path d="M4 9v6l8 5 8-5V9"/>'},
    missing: {title:'You likely need: Tooth Replacement or Bridges', text:'A gap can affect your bite and your smile. We can discuss a bridge or replacement option that fits your mouth and your budget.', icon:'<path d="M12 2v6M12 16v6M4 12h6M14 12h6"/><circle cx="12" cy="12" r="3"/>'},
    stain: {title:'You likely need: Tooth Cleaning', text:'Surface stains usually lift with a professional scale and polish — a quick visit that leaves teeth visibly brighter.', icon:'<path d="M9 2c-3 0-5 2-5 5 0 4 2 5 2.5 9 .3 2 .8 4 2 4s1.5-2 1.5-4 0-3 1-3 1 2 1 4 .3 4 1.5 4 1.7-2 2-4c.5-4 2.5-5 2.5-9 0-3-2-5-5-5-1 0-2 .6-2.5.8C9.5 2.6 8 2 7 2z"/>'},
    crooked: {title:'You likely need: Braces', text:'Misaligned teeth are corrected gradually with braces, tracked visit by visit until your bite and smile line up.', icon:'<rect x="4" y="9" width="16" height="6" rx="3"/><path d="M8 9V7a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>'},
    bleed: {title:'You likely need: General Dental Care', text:'Sore or bleeding gums are worth an exam soon — often it\'s early gum disease, which is easiest to treat when caught early.', icon:'<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>'},
    broken: {title:'You likely need: Crowns or Tooth Injuries care', text:'A chipped or broken tooth is usually rebuilt with a filling or capped with a crown, depending on how much is left.', icon:'<path d="M5 4h14l-1 9a6 6 0 0 1-12 0L5 4z"/>'}
  };
  const chips = document.querySelectorAll('.chip');
  const resultBox = document.getElementById('finderResult');
  function renderResult(key){
    const d = data[key];
    resultBox.style.opacity = 0;
    setTimeout(() => {
      resultBox.innerHTML = `<div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">${d.icon}</svg></div>
        <div><h4>${d.title}</h4><p>${d.text}</p>
        <a href="https://wa.me/233303955466" target="_blank" rel="noopener" class="btn btn-coral btn-sm fr-cta">Ask about this on WhatsApp</a></div>`;
      resultBox.style.opacity = 1;
    }, 150);
  }
  chips.forEach(c => c.addEventListener('click', () => {
    chips.forEach(x => x.classList.remove('active'));
    c.classList.add('active');
    renderResult(c.dataset.key);
  }));
  renderResult('ache');
</script>
