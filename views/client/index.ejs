<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>De Ark Dental Services — Alajo, Accra | General Dental Care</title>
<meta name="description" content="De Ark Dental Services in Alajo, Accra, near Odorgonno Senior High School. Fillings, tooth replacement, RCT, bridges, crowns, braces & general dental care. Call 0303 955 466.">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --blue-deep:#0B2349;
    --blue:#15469E;
    --blue-mid:#1E63C9;
    --blue-light:#5C97E0;
    --sky:#EEF4FC;
    --sky-deep:#DCE9F8;
    --coral:#E63946;
    --coral-deep:#B0212C;
    --ink:#0F2038;
    --slate:#5C6B82;
    --white:#fff;
    --line:rgba(15,32,56,0.1);
    --ease:cubic-bezier(.22,.61,.36,1);
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{font-family:'Inter',sans-serif;background:var(--white);color:var(--ink);-webkit-font-smoothing:antialiased;overflow-x:hidden;}
  img{max-width:100%;display:block;}
  a{color:inherit;text-decoration:none;}
  .container{max-width:1180px;margin:0 auto;padding:0 24px;}
  h1,h2,h3,h4{font-family:'Sora',sans-serif;font-weight:700;line-height:1.12;}
  :focus-visible{outline:2.5px solid var(--coral);outline-offset:3px;}
  @media (prefers-reduced-motion:reduce){*{animation-duration:.01ms!important;transition-duration:.01ms!important;}}

  /* ===== NAV ===== */
  nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;
      padding:16px 24px;background:rgba(255,255,255,0.85);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);
      transition:padding .3s var(--ease), box-shadow .3s var(--ease);}
  nav.scrolled{padding:10px 24px;box-shadow:0 8px 30px -20px rgba(11,35,73,.3);}
  .logo{display:flex;align-items:center;gap:10px;}
  .logo .seal{width:42px;height:42px;border-radius:50%;background:radial-gradient(circle at 30% 30%, var(--blue-light), var(--blue-deep));
      display:flex;align-items:center;justify-content:center;flex-shrink:0;border:2px solid var(--white);box-shadow:0 4px 14px -4px rgba(11,35,73,.5);}
  .logo .seal svg{width:22px;height:22px;}
  .logo .word strong{display:block;font-family:'Sora';font-weight:800;font-size:15px;color:var(--blue-deep);letter-spacing:.01em;}
  .logo .word strong em{color:var(--coral);font-style:normal;}
  .logo .word span{display:block;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--slate);font-weight:600;}
  .nav-links{display:flex;gap:30px;align-items:center;}
  .nav-links a{font-size:14px;font-weight:600;color:var(--blue-deep);position:relative;}
  .nav-links a::after{content:'';position:absolute;left:0;right:0;bottom:-5px;height:2px;background:var(--coral);transform:scaleX(0);transition:transform .3s var(--ease);}
  .nav-links a:hover::after{transform:scaleX(1);}
  .nav-actions{display:flex;align-items:center;gap:12px;}
  .burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;}
  .burger span{width:22px;height:2px;background:var(--blue-deep);display:block;}

  .btn{display:inline-flex;align-items:center;gap:9px;font-family:'Inter';font-weight:700;font-size:14px;
      padding:13px 24px;border-radius:10px;border:none;cursor:pointer;transition:transform .3s var(--ease), box-shadow .3s var(--ease), background .25s;}
  .btn-coral{background:var(--coral);color:#fff;box-shadow:0 10px 24px -8px rgba(230,57,70,.55);}
  .btn-coral:hover{transform:translateY(-2px);background:var(--coral-deep);}
  .btn-blue{background:var(--blue-deep);color:#fff;}
  .btn-blue:hover{transform:translateY(-2px);background:var(--blue);}
  .btn-ghost{background:transparent;border:1.5px solid var(--blue-deep);color:var(--blue-deep);}
  .btn-ghost:hover{background:var(--blue-deep);color:#fff;}
  .btn-sm{padding:9px 16px;font-size:13px;border-radius:8px;}

  /* ===== mobile panel ===== */
  .mpanel{position:fixed;inset:0;background:var(--blue-deep);z-index:300;display:flex;flex-direction:column;
      align-items:center;justify-content:center;gap:26px;transform:translateY(-100%);transition:transform .45s var(--ease);}
  .mpanel.open{transform:translateY(0);}
  .mpanel a{color:#fff;font-family:'Sora';font-size:26px;font-weight:700;}
  .mpanel .close{position:absolute;top:22px;right:24px;background:none;border:none;color:#fff;font-size:28px;cursor:pointer;}

  /* ===== HERO ===== */
  .hero{position:relative;padding:150px 0 90px;background:linear-gradient(180deg,var(--sky) 0%, #fff 100%);overflow:hidden;}
  .hero::before{content:'';position:absolute;top:-220px;right:-180px;width:560px;height:560px;border-radius:50%;
      background:radial-gradient(circle, rgba(21,70,158,.10), transparent 70%);}
  .hero-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:50px;align-items:center;position:relative;z-index:2;}
  .eyebrow{display:inline-flex;align-items:center;gap:9px;font-size:12.5px;font-weight:700;letter-spacing:.1em;
      text-transform:uppercase;color:var(--coral);margin-bottom:18px;}
  .eyebrow::before{content:'';width:8px;height:8px;border-radius:50%;background:var(--coral);display:inline-block;
      box-shadow:0 0 0 4px rgba(230,57,70,.18);}
  .hero h1{font-size:clamp(38px,5vw,56px);color:var(--blue-deep);}
  .hero h1 .accent{color:var(--coral);}
  .hero p.lead{margin-top:20px;font-size:17px;color:var(--slate);max-width:480px;line-height:1.65;}
  .hero-ctas{display:flex;gap:14px;margin-top:32px;flex-wrap:wrap;}
  .hero-numbers{display:flex;gap:10px;margin-top:30px;flex-wrap:wrap;}
  .hero-numbers a{font-family:'Sora';font-weight:700;font-size:13.5px;color:var(--blue-deep);background:#fff;
      border:1px solid var(--line);padding:9px 14px;border-radius:100px;display:flex;align-items:center;gap:8px;
      box-shadow:0 6px 16px -10px rgba(11,35,73,.2);}
  .hero-numbers svg{width:14px;height:14px;color:var(--coral);}

  /* signature: rotating seal + orbiting service dots */
  .seal-wrap{position:relative;width:100%;max-width:420px;margin:0 auto;aspect-ratio:1;}
  .seal-ring{position:absolute;inset:0;border-radius:50%;border:2px dashed rgba(21,70,158,.25);animation:spin 38s linear infinite;}
  .seal-ring2{position:absolute;inset:34px;border-radius:50%;border:1px solid rgba(230,57,70,.25);}
  @keyframes spin{to{transform:rotate(360deg);}}
  .seal-core{position:absolute;inset:90px;border-radius:50%;background:radial-gradient(circle at 32% 28%, var(--blue-light), var(--blue-deep) 70%);
      box-shadow:0 30px 60px -20px rgba(11,35,73,.55), inset 0 0 0 8px rgba(255,255,255,.12);
      display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;text-align:center;padding:14px;}
  .seal-core svg{width:46px;height:46px;margin-bottom:8px;}
  .seal-core .line1{font-family:'Sora';font-weight:800;font-size:15px;letter-spacing:.02em;}
  .seal-core .line2{font-size:10px;letter-spacing:.14em;text-transform:uppercase;opacity:.8;margin-top:4px;}
  .orbit-dot{position:absolute;width:54px;height:54px;border-radius:50%;background:#fff;box-shadow:0 10px 24px -10px rgba(11,35,73,.35);
      display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--blue-deep);
      border:1px solid var(--line);text-align:center;line-height:1.1;animation:floatDot 6s ease-in-out infinite;}
  @keyframes floatDot{0%,100%{transform:translateY(0);}50%{transform:translateY(-10px);}}
  .orbit-dot.coral{color:var(--coral);}

  /* ===== trust strip ===== */
  .trust{background:var(--blue-deep);padding:20px 0;}
  .trust .container{display:flex;justify-content:space-between;flex-wrap:wrap;gap:16px;}
  .trust .t{display:flex;align-items:center;gap:9px;color:#cfe0f7;font-size:13px;font-weight:600;}
  .trust .t svg{width:17px;height:17px;color:var(--coral);flex-shrink:0;}

  /* ===== sections base ===== */
  section{padding:96px 0;}
  .shead{max-width:600px;margin-bottom:48px;}
  .shead.center{margin-inline:auto;text-align:center;}
  .shead h2{font-size:clamp(28px,3.4vw,40px);color:var(--blue-deep);}
  .shead p{margin-top:14px;color:var(--slate);font-size:16px;}

  [data-reveal]{opacity:0;transform:translateY(38px);filter:blur(4px);
      transition:opacity .9s var(--ease), transform .9s var(--ease), filter .9s var(--ease);}
  [data-reveal].in{opacity:1;transform:none;filter:blur(0);}

  /* ===== symptom finder (signature interactive) ===== */
  .finder{background:var(--sky);}
  .finder-chips{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:36px;}
  .chip{background:#fff;border:1.5px solid var(--line);padding:11px 18px;border-radius:100px;font-size:14px;font-weight:600;
      color:var(--blue-deep);cursor:pointer;transition:all .25s var(--ease);}
  .chip:hover{border-color:var(--blue-mid);}
  .chip.active{background:var(--coral);border-color:var(--coral);color:#fff;box-shadow:0 10px 22px -10px rgba(230,57,70,.5);}
  .finder-result{background:#fff;border-radius:18px;padding:30px 32px;border:1px solid var(--line);
      display:flex;gap:22px;align-items:flex-start;box-shadow:0 20px 50px -30px rgba(11,35,73,.3);
      transition:opacity .3s, transform .3s;}
  .finder-result .ico{width:54px;height:54px;border-radius:14px;background:var(--sky-deep);display:flex;
      align-items:center;justify-content:center;flex-shrink:0;}
  .finder-result .ico svg{width:26px;height:26px;color:var(--blue-deep);}
  .finder-result h4{font-size:19px;color:var(--blue-deep);margin-bottom:6px;}
  .finder-result p{color:var(--slate);font-size:14.5px;line-height:1.6;}
  .finder-result .fr-cta{margin-top:14px;}

  /* ===== services bento ===== */
  .svc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;}
  .svc-pill{background:#fff;border:1px solid var(--line);border-radius:16px;padding:24px 20px;transition:transform .35s var(--ease), box-shadow .35s var(--ease), border-color .3s;}
  .svc-pill:hover{transform:translateY(-5px);box-shadow:0 22px 44px -28px rgba(11,35,73,.35);border-color:transparent;}
  .svc-pill .ico{width:42px;height:42px;border-radius:11px;background:var(--sky-deep);display:flex;align-items:center;justify-content:center;margin-bottom:14px;}
  .svc-pill .ico svg{width:20px;height:20px;color:var(--blue-deep);}
  .svc-pill h4{font-size:15px;color:var(--ink);}
  .svc-pill.wide{grid-column:span 2;background:var(--blue-deep);color:#fff;display:flex;flex-direction:column;justify-content:center;}
  .svc-pill.wide .ico{background:rgba(255,255,255,.14);}
  .svc-pill.wide .ico svg{color:#fff;}
  .svc-pill.wide h4{color:#fff;font-size:17px;}
  .svc-pill.wide p{color:#cfe0f7;font-size:13.5px;margin-top:6px;}

  /* ===== why / split ===== */
  .split{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;}
  .why-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:30px;}
  .why-card{background:var(--sky);border-radius:14px;padding:20px;}
  .why-card .n{font-family:'Sora';font-weight:800;font-size:26px;color:var(--coral);}
  .why-card h4{font-size:14.5px;color:var(--blue-deep);margin-top:6px;}
  .why-card p{font-size:13px;color:var(--slate);margin-top:4px;}
  .stamp-visual{position:relative;height:420px;border-radius:22px;background:linear-gradient(150deg,var(--blue-deep),var(--blue));
      display:flex;align-items:center;justify-content:center;overflow:hidden;}
  .stamp-visual::before{content:'';position:absolute;inset:-30%;background:radial-gradient(circle, rgba(255,255,255,.12), transparent 60%);
      animation:driftGlow 6s ease-in-out infinite;}
  @keyframes driftGlow{0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(4%,-4%) scale(1.08);}}
  .stamp-visual svg{width:160px;height:160px;color:#fff;position:relative;z-index:2;opacity:.92;}

  /* ===== location / contact ===== */
  .loc{background:var(--sky);}
  .loc-grid{display:grid;grid-template-columns:1fr 1fr;gap:50px;}
  .map-wrap{border-radius:18px;overflow:hidden;height:380px;border:1px solid var(--line);}
  .map-wrap iframe{width:100%;height:100%;border:0;}
  .info-card{background:#fff;border-radius:16px;padding:24px;border:1px solid var(--line);margin-bottom:16px;display:flex;gap:16px;align-items:flex-start;}
  .info-card .ico{width:44px;height:44px;border-radius:12px;background:var(--sky-deep);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .info-card .ico svg{width:21px;height:21px;color:var(--blue-deep);}
  .info-card h4{font-size:13px;text-transform:uppercase;letter-spacing:.06em;color:var(--slate);margin-bottom:6px;}
  .info-card .val{font-size:15.5px;font-weight:600;color:var(--ink);}
  .info-card .val a{color:var(--ink);}
  .info-card .val a:hover{color:var(--coral);}

  /* ===== CTA band ===== */
  .ctaband{background:linear-gradient(120deg,var(--blue-deep),var(--blue));border-radius:26px;padding:60px 50px;
      color:#fff;display:flex;justify-content:space-between;align-items:center;gap:30px;position:relative;overflow:hidden;}
  .ctaband::before{content:'';position:absolute;right:-60px;bottom:-60px;width:260px;height:260px;border-radius:50%;
      background:radial-gradient(circle, rgba(230,57,70,.35), transparent 70%);}
  .ctaband h2{color:#fff;font-size:clamp(24px,2.8vw,34px);max-width:460px;}
  .ctaband p{color:#cfe0f7;margin-top:8px;}
  .cta-actions{display:flex;gap:12px;flex-wrap:wrap;}

  /* ===== footer ===== */
  footer{background:var(--blue-deep);color:#cfe0f7;padding:64px 0 0;}
  .f-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1.1fr;gap:46px;padding-bottom:40px;border-bottom:1px solid rgba(255,255,255,.12);}
  .f-grid h4{color:#fff;font-size:13px;letter-spacing:.08em;text-transform:uppercase;margin-bottom:16px;font-family:'Inter';font-weight:700;}
  .f-grid li{list-style:none;margin-bottom:9px;font-size:14px;}
  .f-grid a:hover{color:#fff;}
  .f-bottom{display:flex;justify-content:space-between;padding:20px 0 28px;font-size:12.5px;color:#9fb8db;flex-wrap:wrap;gap:10px;}

  .float-wa{position:fixed;bottom:24px;right:24px;z-index:150;width:58px;height:58px;border-radius:50%;background:#25D366;
      display:flex;align-items:center;justify-content:center;box-shadow:0 14px 30px -8px rgba(37,211,102,.6);animation:pulseWA 2.6s infinite;}
  .float-wa svg{width:28px;height:28px;fill:#fff;}
  @keyframes pulseWA{0%,100%{box-shadow:0 14px 30px -8px rgba(37,211,102,.6);}50%{box-shadow:0 14px 30px -8px rgba(37,211,102,.95),0 0 0 10px rgba(37,211,102,.12);}}

  @media (max-width:980px){
    .hero-grid{grid-template-columns:1fr;}
    .svc-grid{grid-template-columns:repeat(2,1fr);}
    .svc-pill.wide{grid-column:span 2;}
    .split{grid-template-columns:1fr;}
    .why-grid{grid-template-columns:1fr 1fr;}
    .loc-grid{grid-template-columns:1fr;}
    .f-grid{grid-template-columns:1fr 1fr;row-gap:30px;}
    .ctaband{flex-direction:column;text-align:center;padding:42px 26px;}
  }

  @media (max-width:680px){

  nav{
    padding:14px 16px;
  }

  .logo{
    min-width:0;
    flex:1;
  }

  .logo .seal{
    width:36px;
    height:36px;
  }

  .logo .word strong{
    font-size:13px;
  }

  .logo .word span{
    font-size:9px;
    letter-spacing:.1em;
  }

  .nav-links{
    display:none;
  }

  /* HIDE DESKTOP BUTTONS */
  .nav-actions .btn{
    display:none;
  }

  .burger{
    display:flex;
  }

  .nav-actions{
    gap:0;
  }

  .svc-grid{
    grid-template-columns:1fr;
  }

  .svc-pill.wide{
    grid-column:span 1;
  }

  .why-grid{
    grid-template-columns:1fr;
  }

  .f-grid{
    grid-template-columns:1fr;
  }

  .trust .container{
    justify-content:center;
    text-align:center;
  }
}
@media (max-width:680px){

  .nav-actions .btn-ghost{
    display:none;
  }

  .nav-actions .btn-coral{
    display:inline-flex;
    padding:8px 12px;
    font-size:12px;
  }

  .burger{
    display:flex;
  }
}
</style>
</head>
<body>

<nav>
  <a href="#top" class="logo">
    <span class="seal">
      <svg viewBox="0 0 24 24" fill="none"><path d="M12 3C9 3 6.5 5.2 6.5 8.3c0 2.7 1.1 3.5 1.6 6 .3 1.4.6 3 1.4 4.2.4.7 1.2 1.2 1.7.4.4-.6.4-1.6.4-2.4 0-1 0-2 .9-2.1 1-.1.9 1.3.9 2.1 0 .8-.1 1.8.4 2.4.5.7 1.2.3 1.6-.4.8-1.2 1.1-2.8 1.4-4.2.5-2.5 1.6-3.3 1.6-6C17.5 5.2 15 3 12 3z" fill="#fff"/></svg>
    </span>
    <span class="word"><strong>DE ARK <em>DENTAL</em></strong><span>Services</span></span>
  </a>
  <div class="nav-links">
    <a href="#services">Services</a>
    <a href="#finder">Find your fix</a>
    <a href="#about">About</a>
    <a href="#location">Location</a>
  </div>
  <div class="nav-actions">
    <a href="tel:+233303955466" class="btn btn-ghost btn-sm">Call Now</a>
    <a href="/book" target="_blank" rel="noopener" class="btn btn-coral btn-sm">Book an appointment</a>
    <button class="burger" aria-label="Open menu"><span></span><span></span><span></span></button>
  </div>
</nav>

<div class="mpanel">
  <button class="close" aria-label="Close menu">&times;</button>
  <a href="#services">Services</a>
  <a href="#finder">Find your fix</a>
  <a href="#about">About</a>
  <a href="#location">Location</a>
  <a href="/book" target="_blank" rel="noopener" class="btn btn-coral" style="margin-top:8px;">Book a visit</a>
</div>

<section class="hero" id="top">
  <div class="container hero-grid">
    <div data-reveal>
      <p class="eyebrow">Ahlaku Street · Alajo, Accra</p>
      <h1>Your oral health,<br><span class="accent">our priority.</span></h1>
      <p class="lead">General dental care for the whole family in the heart of Alajo — fillings, root canal treatment, crowns, bridges, braces and more, just by Odorgonno Senior High School.</p>
      <div class="hero-ctas">
        <a href="/book" target="_blank" rel="noopener" class="btn btn-coral">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm5.6 14.1c-.2.6-1.4 1.2-1.9 1.3-.5.1-1.1.2-3.3-.7-2.7-1.1-4.5-3.9-4.6-4.1-.1-.2-1.1-1.4-1.1-2.7 0-1.3.7-1.9 1-2.2.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5.2.5.7 1.7.7 1.8.1.2.1.3 0 .5-.1.2-.2.3-.3.4l-.5.5c-.2.2-.3.4-.1.7.2.4 1 1.5 2.1 2.4 1.4 1.2 2.3 1.5 2.7 1.7.3.1.5.1.7-.1l.8-.9c.2-.3.4-.2.7-.1l1.6.8c.2.1.4.2.4.4.1.2.1.8-.1 1.4z"/></svg>
          Book a visit
        </a>
        <a href="#finder" class="btn btn-ghost">What's bothering you?</a>
      </div>
      <div class="hero-numbers">
        <a href="tel:+233303955466"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13 1 .37 1.99.7 2.93a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.15-1.27a2 2 0 0 1 2.11-.45c.94.33 1.93.57 2.93.7A2 2 0 0 1 22 16.92z"/></svg>0303 955 466</a>
        <a href="tel:+233574143822">0574 143 822</a>
        <a href="tel:+233263226975">0263 226 975</a>
      </div>
    </div>

    <div data-reveal>
      <div class="seal-wrap">
        <div class="seal-ring"></div>
