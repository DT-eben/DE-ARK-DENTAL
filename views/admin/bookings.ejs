<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bookings — <%= site.name %></title>
  <link rel="stylesheet" href="/css/main.css">
  <style>:root { --accent: <%= site.accent %>; }</style>
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar"><div class="topbar-title">Bookings</div></div>

    <div class="content-area">
      <% if (success && success.length > 0) { %><div class="alert alert-success"><%= success[0] %></div><% } %>

      <div class="card" style="margin-bottom:20px;">
        <form method="GET" action="/admin/bookings" style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap;">
          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label">Date</label>
            <input type="date" name="date" class="form-control" value="<%= selectedDate %>">
          </div>
          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label">Status</label>
            <select name="status" class="form-control">
              <option value="">All</option>
              <option value="pending" <%= selectedStatus === 'pending' ? 'selected' : '' %>>Pending</option>
              <option value="confirmed" <%= selectedStatus === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
              <option value="completed" <%= selectedStatus === 'completed' ? 'selected' : '' %>>Completed</option>
              <option value="cancelled" <%= selectedStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
            </select>
          </div>
          <button type="submit" class="btn btn-primary btn-sm">Filter</button>
          <% if (selectedDate || selectedStatus) { %><a href="/admin/bookings" class="btn btn-ghost btn-sm">Clear</a><% } %>
          <a href="/admin/bookings?date=<%= today %>" class="btn btn-ghost btn-sm" style="margin-left:auto;">Today</a>
        </form>
      </div>

      <div class="card card-flush">
        <% if (appointments.length === 0) { %>
          <div class="empty-state">
            <div class="empty-title">No bookings found</div>
            <p class="empty-desc">Try adjusting your filters.</p>
          </div>
        <% } else { %>
          <table class="data-table">
            <thead><tr><th>Client</th><th>Service</th><th>Date</th><th>Time</th><th>Reference</th><th>Status</th><th>Action</th></tr></thead>
            <tbody>
              <% appointments.forEach(appt => { %>
              <tr>
                <td>
                  <div class="cell-name"><%= appt.customerName %></div>
                  <div class="cell-sub"><%= appt.customerPhone %></div>
                </td>
                <td><%= appt.service.name %><% if (appt.service.price > 0) { %><div class="cell-sub">GH₵ <%= appt.service.price %></div><% } %></td>
                <td><%= appt.date %></td>
                <td>
                  <div class="cell-time"><%= formatTime12(appt.startTime) %></div>
                  <div class="cell-time-end">until <%= formatTime12(appt.endTime) %></div>
                </td>
                <td><span class="cell-sub" style="font-family:var(--font-display);font-weight:600;color:var(--ink-soft);"><%= appt.refNumber %></span></td>
                <td><span class="pill pill-<%= appt.status %>"><%= appt.status %></span></td>
                <td>
                  <div style="display:flex;gap:6px;">
                    <% if (appt.status === 'pending') { %>
                      <button class="btn btn-sm btn-outline status-btn" data-id="<%= appt._id %>" data-status="confirmed">Confirm</button>
                      <button class="btn btn-sm btn-danger-text status-btn" data-id="<%= appt._id %>" data-status="cancelled">Cancel</button>
                    <% } else if (appt.status === 'confirmed') { %>
                      <button class="btn btn-sm btn-ghost status-btn" data-id="<%= appt._id %>" data-status="completed">Mark done</button>
                      <button class="btn btn-sm btn-danger-text status-btn" data-id="<%= appt._id %>" data-status="cancelled">Cancel</button>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.status-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    if (btn.dataset.status === 'cancelled' && !confirm('Cancel this booking?')) return;
    const res = await fetch(`/admin/bookings/${btn.dataset.id}/status`, {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ status: btn.dataset.status })
    });
    const data = await res.json();
    if (data.success) location.reload();
  });
});
</script>
</body>
</html>
